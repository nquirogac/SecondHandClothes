### Example local env for development
# Copy this file to `.env` (do NOT commit `.env` to git)

VITE_FIREBASE_API_KEY="MY_FIREBASE_API_KEY"
VITE_FIREBASE_AUTH_DOMAIN="MY_FIREBASE_AUTH_DOMAIN"
VITE_FIREBASE_PROJECT_ID="MY_FIREBASE_PROJECT_ID"
VITE_FIREBASE_STORAGE_BUCKET="MY_FIREBASE_STORAGE_BUCKET"
VITE_FIREBASE_MESSAGING_SENDER_ID="MY_FIREBASE_MESSAGING_SENDER_ID"
VITE_FIREBASE_APP_ID="MY_FIREBASE_APP_ID"

# Turnstile site key (client) - set your own from Cloudflare
VITE_TURNSTILE_SITE_KEY="MY_TURNSTILE_SITE_KEY"

# Turnstile secret key (server) - must be kept secret
TURNSTILE_SECRET_KEY="MY_TURNSTILE_SECRET_KEY"

# Firebase Admin service account
FIREBASE_SERVICE_ACCOUNT_PATH="./service-account.json"
# FIREBASE_SERVICE_ACCOUNT_JSON=""
